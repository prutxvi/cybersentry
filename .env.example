# NVIDIA NIM API Configuration
# Get your free API key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-api-key-here

# Target URL for Security Audit
# IMPORTANT: Only scan websites you own or have explicit authorization to scan
TARGET_URL=https://your-own-website.com

# Optional: LLM Model Selection (default: meta/llama-3.1-70b-instruct)
# LLM_MODEL=meta/llama-3.1-70b-instruct

# Optional: API Endpoint (default: https://integrate.api.nvidia.com)
# NVIDIA_API_ENDPOINT=https://integrate.api.nvidia.com

# Optional: Logging Level (default: INFO)
# LOG_LEVEL=INFO
